# ─────────────────────────────────────────────────────────────
# RN Coin Hunt — Bot Environment Variables
# Copy this file, rename it to ".env", and fill in your values
# ─────────────────────────────────────────────────────────────

# Your Telegram Bot Token (from @BotFather)
BOT_TOKEN=8718584802:AAHswaep8g16-H6q_ezOewkQzsfEdhX6xPA

# Telegram User IDs of admins (comma separated, no spaces)
ADMIN_TELEGRAM_IDS=1414414216,7728185213

# URL of your User Mini App (from Render, ends with /user-app/)
MINI_APP_URL=https://YOUR-APP-NAME.onrender.com/user-app/

# Base URL of your server (from Render, no trailing slash)
SERVER_URL=https://YOUR-APP-NAME.onrender.com

# Your Telegram Bot username (without @)
BOT_USERNAME=YourBotUsername

# Firebase Admin SDK Service Account JSON (paste entire JSON as one line)
# Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}
